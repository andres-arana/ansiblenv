[core]
  excludesfile = ~/.gitignore
	pager = delta

[color]
  branch = auto
  diff = auto
  status = auto

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red bold
  new = green bold

[color "status"]
  added = yellow
  changed = green
  untracked = cyan

[fetch]
  prune = true

[alias]
  ignore = "!gi() { curl -sL https://www.toptal.com/developers/gitignore/api/$@ ;}; gi"
  graph = log --all --graph --decorate --oneline

[pull]
  ff = only

[push]
  autoSetupRemote = true

[commit]
  verbose = true

[branch]
  sort = -committerdate

[column]
  ui = auto

[tag]
  sort = -version:refname

[interactive]
  diffFilter = delta --color-only

[merge]
  conflictStyle = zdiff3

[delta]
  navigate = true
  dark = true
  side-by-side = true
